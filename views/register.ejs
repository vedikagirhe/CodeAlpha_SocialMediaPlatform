<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">

    <meta name="viewport"
          content="width=device-width, initial-scale=1.0">

    <title>Register | SocialConnect</title>

    <link rel="stylesheet" href="/css/style.css">
</head>

<body class="auth-body">

<div class="auth-container">

    <div class="brand-section">

        <h1>SocialConnect</h1>

        <p>
            Create your profile and start connecting
            with the world.
        </p>

    </div>

    <div class="auth-card">

        <h2>Create Account</h2>

        <p class="subtitle">
            Join the SocialConnect community
        </p>

        <% if (error) { %>

            <p class="error">
                <%= error %>
            </p>

        <% } %>

        <form action="/register" method="POST">

            <input
                type="text"
                name="username"
                placeholder="Username"
                required
            >

            <input
                type="email"
                name="email"
                placeholder="Email Address"
                required
            >

            <input
                type="password"
                name="password"
                placeholder="Password"
                minlength="6"
                required
            >

            <button type="submit">
                Create Account
            </button>

        </form>

        <p class="switch-text">

            Already have an account?

            <a href="/">
                Login
            </a>

        </p>

    </div>

</div>

</body>
</html>