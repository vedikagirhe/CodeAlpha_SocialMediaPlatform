<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <title>Edit Profile | SocialConnect</title>

    <link rel="stylesheet" href="/css/style.css">
</head>

<body>

<nav class="navbar">
    <a href="/home" class="logo">Social<span>Connect</span></a>

    <div class="nav-links">
        <a href="/home">Home</a>
        <a href="/profile/<%= user._id %>">My Profile</a>
    </div>
</nav>

<div class="edit-page">

    <div class="edit-card">

        <div class="edit-header">
            <div class="large-avatar">
                <%= user.username.charAt(0).toUpperCase() %>
            </div>

            <h1>Edit Profile</h1>

            <p>Personalize your SocialConnect profile.</p>
        </div>

        <% if (error) { %>
            <div class="error"><%= error %></div>
        <% } %>

        <form action="/edit-profile"
      method="POST"
      enctype="multipart/form-data"
      class="edit-profile-form">

      <div class="form-group">
    <label>Profile Picture</label>

    <input
        type="file"
        name="profileImage"
        accept="image/*"
    >
</div>
            <label>Username</label>

            <input
                type="text"
                name="username"
                value="<%= user.username %>"
                required
            >

            <label>About Me</label>

            <textarea
                name="bio"
                maxlength="200"
                placeholder="Tell people something about yourself..."
            ><%= user.bio || "" %></textarea>

            <div class="edit-actions">

                <a href="/profile/<%= user._id %>" class="cancel-button">
                    Cancel
                </a>

                <button type="submit">
                    Save Changes
                </button>

            </div>

        </form>

    </div>

</div>

</body>
</html>